# Maintainer: Rodrigo Tavares
_pkgname=dashlane-cli
pkgname=${_pkgname}-bin
pkgver=6.2628.0
pkgrel=1
pkgdesc="Dashlane CLI"
arch=('x86_64')
url="https://github.com/Dashlane/${_pkgname}"
license=('Apache-2.0')
provides=("${_pkgname}")
conflicts=("${_pkgname}-git")

sha256sums_x86_64=('a058d6174581ec580c5f82920c70faf20954bd32bf4bc1f88925aea8a67ae1f2')
source_x86_64=("dcli::https://github.com/Dashlane/${_pkgname}/releases/download/v${pkgver}/dcli-linux-x64")
noextract=('dcli')

OPTIONS=(!strip)

package() {
  install -d -m755 "${pkgdir}/opt/${pkgname}"
  install -d -m755 "${pkgdir}/opt/${pkgname}/bin"
  install -d -m755 "${pkgdir}/usr/bin"
  install -m755 "${srcdir}/dcli" "${pkgdir}/opt/${pkgname}/bin/dcli"
  ln -s "/opt/${pkgname}/bin/dcli" "${pkgdir}/usr/bin/dcli"
}