post_install() {
	post_upgrade
}

post_upgrade() {
	/usr/bin/pacman-key -a /usr/share/rodrigost23-keyring/public.gpg
	KEY=$(gpg --show-keys --with-colons /usr/share/rodrigost23-keyring/public.gpg | grep '^pub' | cut -d: -f5)
	/usr/bin/pacman-key --lsign-key ${KEY}
}

pre_remove() {
	KEY=$(gpg --show-keys --with-colons /usr/share/rodrigost23-keyring/public.gpg | grep '^pub' | cut -d: -f5)
	/usr/bin/pacman-key -d ${KEY}
}
